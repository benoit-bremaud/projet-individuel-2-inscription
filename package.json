{
  "name": "projet-individuel-2-inscription",
  "version": "0.1.0",
  "private": true,
  "description": "App d'inscription full-stack (React / FastAPI / MySQL / Adminer) — Projet Individuel 2 Ynov CI/CD.",
  "author": "Benoît Bremaud <benoit.bremaud@ynov.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benoit-bremaud/projet-individuel-2-inscription.git"
  },
  "keywords": [
    "react",
    "fastapi",
    "mysql",
    "docker",
    "ci-cd",
    "ynov"
  ],
  "dependencies": {
    "axios": "^1.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --coverage --collectCoverageFrom=src/**/*.{js,jsx} --collectCoverageFrom=!src/reportWebVitals.js --collectCoverageFrom=!src/index.js --watchAll=false --setupFiles=./.jest/setEnvVars.js",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "jsdoc": "jsdoc -R ./README.md -c ./jsdoc.config.json -r -d ./public/docs",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "homepage": "https://benoit-bremaud.github.io/projet-individuel-2-inscription/",
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!axios)/"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "cypress": "^15.17.0",
    "gh-pages": "^6.3.0",
    "jsdoc": "^4.0.5"
  }
}
